     ]
    }
   ],
   "source": [
    "# ── Overfitting Check ─────────────────────────────────────────────────────────\n",
    "# Compares training scores vs validation scores across 5 folds\n",
    "# A big gap between them = model memorized training data = overfitting\n",
    "print(\"\\n\" + \"=\"*60)\n",
    "print(\"OVERFITTING CHECK\")\n",
    "print(\"=\"*60)\n",
    "\n",
    "# Same CV strategy but now returning BOTH train and validation scores\n",
    "cv_overfit = cross_validate(\n",
    "    best_xgb,\n",
    "    X_train, y_train,\n",
    "    cv                 = cv_strategy,\n",
    "    scoring            = ['accuracy', 'recall', 'f1', 'roc_auc'],\n",
    "    return_train_score = True          # ← This is the key difference\n",
    ")\n",
    "\n",
    "# ── Build Comparison Table ────────────────────────────────────────────────────\n",
    "overfit_summary = pd.DataFrame({\n",
    "    'Metric': ['Accuracy', 'Recall', 'F1-Score', 'ROC-AUC'],\n",
    "    'Train Score': [\n",
    "        cv_overfit['train_accuracy'].mean(),\n",
    "        cv_overfit['train_recall'].mean(),\n",
    "        cv_overfit['train_f1'].mean(),\n",
    "        cv_overfit['train_roc_auc'].mean()\n",
    "    ],\n",
    "    'Val Score': [\n",
    "        cv_overfit['test_accuracy'].mean(),\n",
    "        cv_overfit['test_recall'].mean(),\n",
    "        cv_overfit['test_f1'].mean(),\n",
    "        cv_overfit['test_roc_auc'].mean()\n",
    "    ],\n",
    "}).round(4)\n",
    "\n",
    "# Gap = Train - Val → the key overfitting indicator\n",
    "overfit_summary['Gap'] = (\n",
    "    overfit_summary['Train Score'] - overfit_summary['Val Score']\n",
    ").round(4)\n",
    "\n",
    "# Flag status based on gap size\n",
    "overfit_summary['Status'] = overfit_summary['Gap'].apply(\n",
    "    lambda g: ' Healthy'     if g < 0.05 else\n",
    "              '  Mild'       if g < 0.10 else\n",
    "              ' Overfitting'\n",
    ")\n",
    "\n",
    "print(\"\\nTrain vs Validation Score Comparison:\")\n",
    "print(overfit_summary.to_string(index=False))\n",
    "\n",
    "# ── Overall Verdict ───────────────────────────────────────────────────────────\n",
    "max_gap = overfit_summary['Gap'].max()\n",
    "print(\"\\n\" + \"-\"*40)\n",
    "if max_gap < 0.05:\n",
    "    print(\" VERDICT: No overfitting — model generalizes well\")\n",
    "elif max_gap < 0.10:\n",
    "    print(\"  VERDICT: Mild overfitting — acceptable but monitor\")\n",
    "else:\n",
    "    print(\" VERDICT: Overfitting detected — consider reducing max_depth or increasing min_child_weight\")\n",
    "print(f\"   Largest gap observed: {max_gap:.4f}\")\n",
    "print(\"-\"*40)\n",
    "\n",
    "# Save to CSV\n",
    "overfit_path = os.path.join(EVAL_DIR, f\"{MODEL_NAME}_overfitting_check.csv\")\n",
    "overfit_summary.to_csv(overfit_path, index=False)\n",
    "print(f\"\\nSaved to: {overfit_path}\")"
   ]
  },
