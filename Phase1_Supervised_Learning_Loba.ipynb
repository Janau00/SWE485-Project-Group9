     "text": [
      "\n",
      "============================================================\n",
      "OVERFITTING CHECK\n",
      "============================================================\n",
      "\n",
      "Train vs Validation Score Comparison:\n",
      "  Metric  Train Score  Val Score    Gap   Status\n",
      "Accuracy       0.9335     0.8677 0.0658     Mild\n",
      "  Recall       0.9481     0.9037 0.0444  Healthy\n",
      "F1-Score       0.9403     0.8836 0.0567     Mild\n",
      " ROC-AUC       0.9840     0.9292 0.0548     Mild\n",
