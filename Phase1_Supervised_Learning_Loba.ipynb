   "source": [
    "# ── ROC Curve ─────────────────────────────────────────────────────────────────\n",
    "# ROC curve plots True Positive Rate (Recall) vs False Positive Rate\n",
    "# at every possible classification threshold\n",
    "# AUC (Area Under Curve) → closer to 1.0 = better model discrimination\n",
    "# Diagonal line = random classifier (AUC = 0.50) → our baseline to beat\n",
    "print(\"\\n\" + \"-\"*40)\n",
    "print(\"ROC CURVE\")\n",
    "print(\"-\"*40)\n",
    "\n",
    "# fpr → False Positive Rate at each threshold\n",
    "# tpr → True Positive Rate (Recall) at each threshold\n",
    "# Uses y_pred_prob (probabilities) → threshold-independent evaluation\n",
    "fpr, tpr, _ = roc_curve(y_test, y_pred_prob)\n",
    "auc_score   = roc_auc_score(y_test, y_pred_prob)\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(7, 5))\n",
    "\n",
    "# XGBoost ROC curve\n",
    "ax.plot(fpr, tpr, color='darkorange', lw=2,\n",
    "        label=f'XGBoost (AUC = {auc_score:.4f})')\n",
    "\n",
    "# Random classifier baseline — any good model must be well above this line\n",
    "ax.plot([0, 1], [0, 1], color='grey', linestyle='--', lw=1,\n",
    "        label='Random Classifier (AUC = 0.50)')\n",
    "\n",
    "ax.set_xlabel('False Positive Rate', fontsize=12)\n",
    "ax.set_ylabel('True Positive Rate (Recall)', fontsize=12)\n",
    "ax.set_title('ROC Curve — XGBoost', fontsize=13)\n",
    "ax.legend(loc='lower right')\n",
    "ax.grid(True, alpha=0.3)\n",
    "plt.tight_layout()\n",
    "\n",
    "# Save plot\n",
    "roc_path = os.path.join(PLOTS_DIR, f\"{MODEL_NAME}_roc_curve.png\")\n",
    "plt.savefig(roc_path, dpi=150)\n",
    "plt.show()\n",
    "print(f\"Saved to: {roc_path}\")"
   ]
  },
