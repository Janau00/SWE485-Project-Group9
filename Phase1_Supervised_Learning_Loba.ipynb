   "source": [
    "# ── Feature Importance ────────────────────────────────────────────────────────\n",
    "# XGBoost computes feature importance as \"gain\" by default\n",
    "# Gain → average improvement in loss function brought by a feature across all splits\n",
    "# Higher importance = feature contributes more to reducing prediction error\n",
    "# Useful for: model interpretability, feature selection, and domain validation\n",
    "print(\"\\n\" + \"-\"*40)\n",
    "print(\"FEATURE IMPORTANCE\")\n",
    "print(\"-\"*40)\n",
    "\n",
    "# Extract importance scores from the trained XGBoost model\n",
    "# feature_importances_ returns one score per feature, summing to 1.0\n",
    "importances   = best_xgb.feature_importances_\n",
    "feature_names = X.columns\n",
    "\n",
    "# Build a ranked DataFrame for readability and CSV export\n",
    "importance_df = (\n",
    "    pd.DataFrame({'Feature': feature_names, 'Importance': importances})\n",
    "    .sort_values('Importance', ascending=False)   # Highest impact features first\n",
    "    .reset_index(drop=True)\n",
    ")\n",
    "\n",
    "print(\"\\nFeature importances (ranked highest to lowest):\")\n",
    "print(importance_df.round(4).to_string(index=False))"
   ]
