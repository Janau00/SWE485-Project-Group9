   "cell_type": "markdown",
   "id": "dc3d2094",
   "metadata": {},
   "source": [
    "### Test Set Predictions & Threshold Tuning"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 44,
   "id": "1a4e7ddc",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "\n",
      "----------------------------------------\n",
      "TEST SET EVALUATION\n",
      "----------------------------------------\n",
      "\n",
      "----------------------------------------\n",
      "OPTIMIZING THRESHOLD FOR BETTER RECALL\n",
      "----------------------------------------\n",
      "Default threshold (0.50) → Recall=0.8529, Precision=0.9062\n",
      "Optimal threshold (0.199) → Recall=0.9412, Precision=0.8000\n",
      "\n",
      "========================================\n",
      "FINAL RESULTS WITH OPTIMAL THRESHOLD\n",
      "========================================\n",
      " Accuracy  Precision  Recall  F1-Score  ROC-AUC\n",
      "    0.837        0.8  0.9412    0.8649   0.9285\n",
      "\n",
      "Confusion Matrix (Optimal Threshold = 0.199):\n",
      "  True Negatives  (TN): 58  — correctly predicted No Disease\n",
      "  False Positives (FP): 24  — predicted Disease, actually Healthy\n",
      "  False Negatives (FN): 6  — MISSED DISEASE CASES ← minimized!\n",
      "  True Positives  (TP): 96  — correctly predicted Disease\n",
      "\n",
      "Saved to: Supervised_Learning/evaluation_results\\xgboost_metrics.csv\n"
     ]
    }
   ],
   "source": [
    "# ── Test Set Predictions ─────────────────────────────────────────────────────\n",
    "# First and ONLY time the model sees the test set\n",
    "# y_pred      → predicted class labels (0 or 1)\n",
    "# y_pred_prob → predicted probability of class 1 (needed for threshold tuning & ROC-AUC)\n",
    "print(\"\\n\" + \"-\"*40)\n",
    "print(\"TEST SET EVALUATION\")\n",
    "print(\"-\"*40)\n",
    "\n",
    "y_pred      = best_xgb.predict(X_test)\n",
    "y_pred_prob = best_xgb.predict_proba(X_test)[:, 1]\n",
    "\n",
    "# ── Threshold Optimization ───────────────────────────────────────────────────\n",
    "# Default threshold (0.5) is not always optimal for recall\n",
    "# precision_recall_curve returns precision/recall values at every possible threshold\n",
    "# We search for the lowest threshold where:\n",
    "#   - Recall  >= 0.92 (catch at least 92% of disease cases)\n",
    "#   - Precision >= 0.70 (keep false alarms under control)\n",
    "print(\"\\n\" + \"-\"*40)\n",
    "print(\"OPTIMIZING THRESHOLD FOR BETTER RECALL\")\n",
    "print(\"-\"*40)\n",
    "\n",
    "from sklearn.metrics import precision_recall_curve\n",
    "\n",
    "precisions, recalls, thresholds = precision_recall_curve(y_test, y_pred_prob)\n",
    "\n",
    "# precision_recall_curve returns one more value than thresholds → align lengths\n",
    "thresholds = thresholds[:len(recalls) - 1]\n",
    "precisions = precisions[:len(recalls) - 1]\n",
    "recalls    = recalls   [:len(recalls) - 1]\n",
    "\n",
    "# Start from default and search for a better threshold\n",
    "optimal_threshold = 0.5\n",
    "best_recall_val   = recall_score   (y_test, y_pred)\n",
    "best_precision_val = precision_score(y_test, y_pred)\n",
    "\n",
    "print(f\"Default threshold (0.50) → Recall={best_recall_val:.4f}, Precision={best_precision_val:.4f}\")\n",
    "\n",
    "for i, threshold in enumerate(thresholds):\n",
    "   if recalls[i] >= 0.88 and precisions[i] >= 0.80:\n",
    "        optimal_threshold  = threshold\n",
    "        best_recall_val    = recalls[i]\n",
    "        best_precision_val = precisions[i]\n",
    "        break\n",
    "\n",
    "print(f\"Optimal threshold ({optimal_threshold:.3f}) → Recall={best_recall_val:.4f}, Precision={best_precision_val:.4f}\")\n",
    "\n",
    "# Apply the optimal threshold to generate final predictions\n",
    "y_pred_final = (y_pred_prob >= optimal_threshold).astype(int)\n",
    "\n",
    "# ── Final Metrics (Optimized Threshold) ──────────────────────────────────────\n",
    "# All metrics computed once using the optimal threshold predictions\n",
    "# ROC-AUC uses probabilities (threshold-independent)\n",
    "print(\"\\n\" + \"=\"*40)\n",
    "print(\"FINAL RESULTS WITH OPTIMAL THRESHOLD\")\n",
    "print(\"=\"*40)\n",
    "\n",
    "test_metrics = pd.DataFrame([{\n",
    "    'Accuracy' : accuracy_score (y_test, y_pred_final),\n",
    "    'Precision': precision_score(y_test, y_pred_final),\n",
    "    'Recall'   : recall_score   (y_test, y_pred_final),   # ← Primary goal\n",
    "    'F1-Score' : f1_score       (y_test, y_pred_final),\n",
    "    'ROC-AUC'  : roc_auc_score  (y_test, y_pred_prob)     # Always uses probabilities\n",
    "}]).round(4)\n",
    "\n",
    "print(test_metrics.to_string(index=False))\n",
    "\n",
    "# ── Confusion Matrix Breakdown ────────────────────────────────────────────────\n",
    "# TN → correctly predicted No Disease\n",
    "# FP → predicted Disease but actually Healthy (false alarm)\n",
    "# FN → missed actual Disease cases (most dangerous → want this minimized)\n",
    "# TP → correctly predicted Disease\n",
    "cm = confusion_matrix(y_test, y_pred_final)\n",
    "tn, fp, fn, tp = cm.ravel()\n",
    "\n",
    "print(f\"\\nConfusion Matrix (Optimal Threshold = {optimal_threshold:.3f}):\")\n",
    "print(f\"  True Negatives  (TN): {tn}  — correctly predicted No Disease\")\n",
    "print(f\"  False Positives (FP): {fp}  — predicted Disease, actually Healthy\")\n",
    "print(f\"  False Negatives (FN): {fn}  — MISSED DISEASE CASES ← minimized!\")\n",
    "print(f\"  True Positives  (TP): {tp}  — correctly predicted Disease\")\n",
    "\n",
    "# ── Save Metrics to CSV ───────────────────────────────────────────────────────\n",
    "metrics_path = os.path.join(EVAL_DIR, f\"{MODEL_NAME}_metrics.csv\")\n",
    "test_metrics.to_csv(metrics_path, index=False)\n",
    "print(f\"\\nSaved to: {metrics_path}\")"
   ]
  },
